<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>WiFi Login - TWT Hotspot</title>
</head>

<body>
    <div class="container">
        <div class="header">
            <div>
                <img src="/logo.png" alt="Tiger Wheel & Tyre logo" loading="lazy">
            </div>
            <h1>Registration Complete!</h1>
            <p class="subtitle">✅ Thank you for registering. Now please enter your WiFi credentials to connect.</p>
        </div>

        <form id="wifiLoginForm" action="/wifi-auth" method="POST">
            <div class="wifi-credentials-section">
                <h3>🔐 WiFi Network Login</h3>
                <p class="network-info">Network: <strong>TWT-Guest</strong></p>
                
                <div class="form-group">
                    <label for="username">Username <span class="required">*</span></label>
                    <input 
                        type="text" 
                        id="username" 
                        name="username" 
                        required 
                        placeholder="Enter WiFi username"
                        value="geenet"
                    >
                </div>

                <div class="form-group">
                    <label for="password">Password <span class="required">*</span></label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required 
                        placeholder="Enter WiFi password"
                        value="geenet2025"
                    >
                    <div class="show-password-toggle">
                        <input type="checkbox" id="showPassword" onchange="togglePassword()">
                        <label for="showPassword">Show password</label>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    🚀 Connect to WiFi
                </button>
            </div>
        </form>

        <div class="help-info">
            <p><strong>Default Credentials:</strong></p>
            <ul>
                <li>Username: <code>geenet</code></li>
                <li>Password: <code>geenet2025</code></li>
            </ul>
        </div>
    </div>

    <style>
        .wifi-credentials-section {
            background: #f8f9fa;
            border: 2px solid #e9ecef;
            border-radius: 12px;
            padding: 25px;
            margin: 20px 0;
        }

        .wifi-credentials-section h3 {
            margin: 0 0 15px 0;
            color: #495057;
            text-align: center;
        }

        .network-info {
            text-align: center;
            background: #e3f2fd;
            padding: 10px;
            border-radius: 6px;
            margin-bottom: 20px;
            color: #1565c0;
        }

        .show-password-toggle {
            margin-top: 8px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .show-password-toggle input[type="checkbox"] {
            width: auto;
            margin: 0;
        }

        .show-password-toggle label {
            font-size: 14px;
            color: #6c757d;
            cursor: pointer;
        }

        .form-actions {
            text-align: center;
            margin: 25px 0;
        }

        .btn {
            padding: 15px 30px;
            background: #e53e3e;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn:hover {
            background: #c53030;
            transform: translateY(-1px);
        }

        .help-info {
            background: #fff3cd;
            border: 1px solid #ffeaa7;
            border-radius: 8px;
            padding: 15px;
            margin: 20px 0;
        }

        .help-info p {
            margin: 0 0 10px 0;
            font-weight: bold;
            color: #856404;
        }

        .help-info ul {
            margin: 0;
            padding-left: 20px;
        }

        .help-info li {
            margin: 5px 0;
            color: #856404;
        }

        .help-info code {
            background: #f8f9fa;
            padding: 2px 6px;
            border-radius: 3px;
            font-family: 'Courier New', monospace;
            color: #e83e8c;
        }
    </style>

    <script>
        function togglePassword() {
            const passwordField = document.getElementById('password');
            const showPasswordCheckbox = document.getElementById('showPassword');
            
            if (showPasswordCheckbox.checked) {
                passwordField.type = 'text';
            } else {
                passwordField.type = 'password';
            }
        }

        // Auto-focus username field
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('username').focus();
        });
    </script>
</body>
</html>
