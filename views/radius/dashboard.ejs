<%- include('../partials/header', { 
    title: 'RADIUS Dashboard', 
    currentPage: 'radius-dashboard',
    showBreadcrumb: true,
    breadcrumbs: [
        { name: 'Home', url: '/' },
        { name: 'RADIUS', url: '/radius/dashboard' },
        { name: 'Dashboard', url: '/radius/dashboard' }
    ]
}) %>

<div class="row mb-4">
    <div class="col-12">
        <h1><i class="fas fa-tachometer-alt me-2"></i>RADIUS Dashboard</h1>
        <p class="text-muted">Real-time monitoring and statistics for your RADIUS server</p>
    </div>
</div>

<!-- Stats Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                            Active Sessions
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats ? stats.active_sessions : 0 %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                            Users (24h)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats ? stats.users_24h : 0 %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-user-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-info shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                            Data (24h)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <span id="data-24h"><%= stats ? formatBytes(stats.data_24h) : '0 Bytes' %></span>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-download fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Auth Requests (1h)
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            <%= stats ? stats.auth_1h : 0 %>
                        </div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-key fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row mb-4">
    <div class="col-xl-8 col-lg-7">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-chart-area me-2"></i>Usage Overview
                </h6>
                <div class="dropdown no-arrow">
                    <a class="dropdown-toggle" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown">
                        <i class="fas fa-ellipsis-v fa-sm fa-fw text-gray-400"></i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-right shadow">
                        <div class="dropdown-header">Actions:</div>
                        <a class="dropdown-item" href="#" onclick="refreshChart()">
                            <i class="fas fa-sync fa-sm fa-fw mr-2 text-gray-400"></i>Refresh
                        </a>
                        <a class="dropdown-item" href="/radius/usage">
                            <i class="fas fa-chart-bar fa-sm fa-fw mr-2 text-gray-400"></i>Detailed Reports
                        </a>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="chart-area">
                    <canvas id="myAreaChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-lg-5">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-chart-pie me-2"></i>Traffic Sources
                </h6>
            </div>
            <div class="card-body">
                <div class="chart-pie pt-4 pb-2">
                    <canvas id="myPieChart"></canvas>
                </div>
                <div class="mt-4 text-center small">
                    <span class="mr-2">
                        <i class="fas fa-circle text-primary"></i> Wireless
                    </span>
                    <span class="mr-2">
                        <i class="fas fa-circle text-success"></i> Wired
                    </span>
                    <span class="mr-2">
                        <i class="fas fa-circle text-info"></i> VPN
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="row">
    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-list me-2"></i>Recent Logins
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Time</th>
                                <th>IP</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="recent-logins">
                            <tr>
                                <td colspan="4" class="text-center">
                                    <i class="fas fa-spinner fa-spin"></i> Loading...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-center">
                    <a href="/radius/auth" class="btn btn-primary btn-sm">
                        <i class="fas fa-eye me-1"></i>View All
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-users me-2"></i>Active Sessions
                </h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Duration</th>
                                <th>Data</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="active-sessions">
                            <tr>
                                <td colspan="4" class="text-center">
                                    <i class="fas fa-spinner fa-spin"></i> Loading...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="text-center">
                    <a href="/radius/active" class="btn btn-primary btn-sm">
                        <i class="fas fa-eye me-1"></i>View All
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
// Format bytes function
function formatBytes(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
}

// Format duration
function formatDuration(seconds) {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    const secs = seconds % 60;
    
    if (hours > 0) {
        return `${hours}h ${minutes}m`;
    } else if (minutes > 0) {
        return `${minutes}m`;
    } else {
        return `${secs}s`;
    }
}

// Load dashboard data
function loadDashboardData() {
    // Load recent logins
    fetch('/radius/api/stats')
        .then(response => response.json())
        .then(data => {
            // Update stats if needed
            updateStats(data);
        })
        .catch(error => console.error('Error loading stats:', error));

    // Load active sessions
    fetch('/radius/api/active-sessions')
        .then(response => response.json())
        .then(sessions => {
            updateActiveSessions(sessions);
        })
        .catch(error => console.error('Error loading active sessions:', error));
}

function updateStats(stats) {
    // Update the stats cards with real-time data
    document.querySelector('.border-left-primary .h5').textContent = stats.active_sessions || 0;
    document.querySelector('.border-left-success .h5').textContent = stats.users_24h || 0;
    document.getElementById('data-24h').textContent = formatBytes(stats.data_24h || 0);
    document.querySelector('.border-left-warning .h5').textContent = stats.auth_1h || 0;
}

function updateActiveSessions(sessions) {
    const tbody = document.getElementById('active-sessions');
    if (sessions.length === 0) {
        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No active sessions</td></tr>';
        return;
    }

    tbody.innerHTML = sessions.slice(0, 5).map(session => `
        <tr>
            <td><strong>${session.username}</strong></td>
            <td>${formatDuration(session.acctsessiontime || 0)}</td>
            <td>${formatBytes((session.acctinputoctets || 0) + (session.acctoutputoctets || 0))}</td>
            <td>
                <button class="btn btn-sm btn-outline-danger" onclick="terminateSession(${session.radacctid})">
                    <i class="fas fa-times"></i>
                </button>
            </td>
        </tr>
    `).join('');
}

function terminateSession(sessionId) {
    if (confirm('Are you sure you want to terminate this session?')) {
        fetch('/radius/api/terminate-session', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ sessionId })
        })
        .then(response => response.json())
        .then(result => {
            if (result.success) {
                showNotification('Session terminated successfully', 'success');
                loadDashboardData();
            } else {
                showNotification('Failed to terminate session', 'danger');
            }
        })
        .catch(error => {
            console.error('Error terminating session:', error);
            showNotification('Error terminating session', 'danger');
        });
    }
}

function refreshChart() {
    showNotification('Refreshing charts...', 'info');
    loadDashboardData();
}

// Initialize charts (placeholder)
document.addEventListener('DOMContentLoaded', function() {
    // Initialize area chart
    const ctx = document.getElementById('myAreaChart');
    if (ctx) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['00:00', '04:00', '08:00', '12:00', '16:00', '20:00'],
                datasets: [{
                    label: 'Active Users',
                    data: [12, 19, 3, 17, 28, 24],
                    borderColor: 'rgb(75, 192, 192)',
                    backgroundColor: 'rgba(75, 192, 192, 0.2)',
                    tension: 0.1
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // Initialize pie chart
    const pieCtx = document.getElementById('myPieChart');
    if (pieCtx) {
        new Chart(pieCtx, {
            type: 'pie',
            data: {
                labels: ['Wireless', 'Wired', 'VPN'],
                datasets: [{
                    data: [60, 30, 10],
                    backgroundColor: [
                        'rgb(54, 162, 235)',
                        'rgb(75, 192, 192)',
                        'rgb(255, 205, 86)'
                    ]
                }]
            },
            options: {
                responsive: true
            }
        });
    }

    // Load initial data
    loadDashboardData();

    // Auto-refresh every 30 seconds
    setInterval(loadDashboardData, 30000);
});
</script>

<%- include('../partials/footer') %>
