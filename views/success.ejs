<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Registration Successful - TWT Hotspot</title>
</head>

<body>
    <div class="container">
        <div class="success" id="success">
            <div class="success-icon"></div>
            <h3>Registration Successful!</h3>
            <p>You are now connected to the Wi-Fi network.</p>
            
            <div class="action-section">
                <a href="https://www.google.com" class="btn btn-primary">
                    Go to Brower
                </a>
                <p class="auto-redirect">You will be redirected to browser in <span id="countdown">5</span> seconds...</p>
            </div>
        </div>
    </div>

    <style>
        .success-icon {
            font-size: 48px; /* Adjusted size */
            margin-bottom: 20px;
            animation: bounceIn 1s ease-out;
        }

        .success-icon::before {
            content: '✔'; /* Using a simple checkmark character */
            color: #28a745;
        }

        .action-section {
            margin: 30px 0;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 15px 30px;
            background: #e53e3e;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-size: 18px;
            font-weight: bold;
            transition: all 0.3s ease;
            margin-bottom: 20px;
        }

        .btn:hover {
            background: #c53030;
            transform: translateY(-2px);
        }

        .auto-redirect {
            color: #6c757d;
            font-size: 14px;
            margin: 15px 0 0 0;
        }

        #countdown {
            font-weight: bold;
            color: #e53e3e;
        }

        .success {
            animation: fadeIn 0.5s ease-out;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>

    <script>
        document.getElementById('success').style.display = 'block';
        
        // Countdown and auto-redirect
        let timeLeft = 5;
        const countdownElement = document.getElementById('countdown');
        
        function updateCountdown() {
            countdownElement.textContent = timeLeft;
            timeLeft--;
            
            if (timeLeft < 0) {
                window.location.href = 'https://www.google.com';
            } else {
                setTimeout(updateCountdown, 1000);
            }
        }
        
        // Start countdown after page loads
        setTimeout(updateCountdown, 1000);
        
        // Allow manual navigation
        document.querySelector('.btn').addEventListener('click', function(e) {
            e.preventDefault();
            window.location.href = 'https://www.google.com';
        });
    </script>
</body>
</html>