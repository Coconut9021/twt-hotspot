<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>Wi-Fi Access Portal</title>
</head>

<body>
    <div class="container">
        <div class="header">
            <div>
                <img src="/public/logo.png" alt="Tiger Wheel & Tyre logo" loading="lazy" >
            </div>
            <h1>Welcome to Our Network</h1>
            <p class="subtitle">Please complete the form below to access Wi-Fi</p>
        </div>

        <form id="wifiForm" action="/register" method="POST">
            <div class="form-group">
                <label for="fullName">Full Name <span class="required">*</span></label>
                <input type="text" id="fullName" name="fullName" required>
                <div class="error" id="fullNameError">Please enter your full name</div>
            </div>

            <div class="form-group">
                <label for="email">Email Address <span class="required">*</span></label>
                <input type="email" id="email" name="email" required>
                <div class="error" id="emailError">Please enter a valid email address</div>
            </div>

            <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" placeholder="Optional">
                <div class="error" id="phoneError">Please enter a valid phone number</div>
            </div>

            <div class="form-group">
                <label for="company">Company Name</label>
                <input type="text" id="company" name="company" placeholder="If applicable">
            </div>

            <div class="checkbox-group">
                <input type="checkbox" id="terms" name="terms" required>
                <label for="terms">I agree to the <a href="#" onclick="showTerms()">Terms of Service</a> and Wi-Fi usage policy <span class="required">*</span></label>
            </div>
            <div class="error" id="termsError">You must agree to the Terms of Service</div>

            <div class="checkbox-group">
                <input type="checkbox" id="marketing" name="marketing">
                <label for="marketing">I would like to receive promotional emails and offers (optional)</label>
            </div>

            <button class="submit-btn" style="display: block; text-align: center; text-decoration: none; color: white;">Connect to Wi-Fi</button>
        </form>

    </div>
    <!-- <script src="/public/js/form-validation.js"></script> -->
</body>
</html>